# =============================================================
# DZT Proxy — Environment Configuration
# =============================================================
# Copy this file to .env and fill in your GITHUB_PAT.
# The menu (run_menu.sh) loads this automatically.
# NEVER commit .env with real tokens to git.
# =============================================================

# ── GitHub Personal Access Token ─────────────────────────────
# Required for options 3 and 4 (GitHub MCP attacks).
# Get one from: https://github.com/settings/tokens
GITHUB_PAT=

# ── DID identities ───────────────────────────────────────────
AGENT_DID=did:web:dzt.local:agent1
SERVER_DID=did:web:dzt.local:mcpserver

# ── Key path ─────────────────────────────────────────────────
AGENT_PRIVATE_KEY_PATH=did/keys/agent1_private.pem

# ── JWT settings ─────────────────────────────────────────────
JWT_ALG=ES256K

# ── URLs ─────────────────────────────────────────────────────
GITHUB_MCP_URL=https://api.githubcopilot.com/mcp/
UPSTREAM_URL=http://127.0.0.1:8001/tools/call
